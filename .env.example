# Frontend - Environment Variables
# Copy this file to .env.local and fill in values

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Site URL (for SEO canonical)
NEXT_PUBLIC_SITE_URL=https://icc.ma

# WhatsApp Number (for floating button)
NEXT_PUBLIC_WHATSAPP_NUMBER=+212663216912
NEXT_PUBLIC_WHATSAPP_MESSAGE=Bonjour%21%20Je%20souhaite%20des%20informations

# Phone Numbers
NEXT_PUBLIC_PHONE_PRIMARY=+212522980801
NEXT_PUBLIC_PHONE_SECONDARY=+212663216912

# Email
NEXT_PUBLIC_EMAIL=contact@icc.ma

# Google Maps API Key (optional, for contact page map)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
